NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Payment provider selector (current: sepay)
PAYMENT_PROVIDER=sepay

# VietQR checkout (server-side trusted order flow)
# Ví dụ ngân hàng MB: 970422
VIETQR_BANK_BIN=970422
VIETQR_ACCOUNT_NO=0937534192
VIETQR_ACCOUNT_NAME=DOC2SHARE
VIETQR_TEMPLATE=compact2
# SePay webhook API key (Authorization: Apikey <key>)
WEBHOOK_SEPAY_API_KEY=replace-with-your-sepay-webhook-key

# Optional: SEO & Community (Docs_Chiến lược SEO, Cộng đồng mạng)
# NEXT_PUBLIC_APP_URL=https://doc2share.vn
# NEXT_PUBLIC_COMMUNITY_ZALO=https://zalo.me/g/xxxxx
# NEXT_PUBLIC_COMMUNITY_TELEGRAM=https://t.me/doc2share

# Optional: signed diagnostics link (admin observability sharing)
# DIAGNOSTICS_SHARE_SECRET=replace-with-long-random-secret

# Optional: webhook when observability alerts fire (after Run maintenance)
# ALERT_WEBHOOK_URL=https://hooks.slack.com/... or your endpoint
# ALERT_WEBHOOK_SECRET=optional-secret-sent-as-X-Webhook-Secret-header

# Optional: internal cron route auth for document async pipeline worker
# INTERNAL_CRON_SECRET=replace-with-random-secret
